# Production Environment Template
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the actual .env file to version control.

# App
PORT=5000
# Must be 'production' in all production deployments
NODE_ENV=production
# Set to your actual production domain (e.g. https://krishiconnect.com)
CORS_ORIGIN=https://your-production-domain.com

# Database (PostgreSQL)
# Use a strong, unique password
POSTGRES_USER=krishi
POSTGRES_PASSWORD=change_this_to_a_secure_random_string
POSTGRES_DB=krishi_connect
DATABASE_URL=postgresql://krishi:change_this_to_a_secure_random_string@localhost:5432/krishi_connect?schema=public

# Redis
# Use a strong, unique password
REDIS_PASSWORD=change_this_to_a_secure_random_string
REDIS_URL=redis://:change_this_to_a_secure_random_string@localhost:6379

# Auth (JWT)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_secure_random_string
JWT_REFRESH_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads/

# Razorpay (Payment Gateway)
# Obtain from your Razorpay dashboard: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Map/Geolocation
MAP_API_KEY=your_map_api_key_here
