# App
PORT=5000
NODE_ENV=development  # Set to 'production' in production environments
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
POSTGRES_USER=krishi
POSTGRES_PASSWORD=your_password
POSTGRES_DB=krishi_connect
DATABASE_URL=postgresql://krishi:your_password@localhost:5432/krishi_connect?schema=public

# Redis
REDIS_PASSWORD=change_this_to_a_secure_random_string
REDIS_URL=redis://:change_this_to_a_secure_random_string@localhost:6379

# Auth (JWT)
JWT_SECRET=change_this_to_a_secure_random_string
JWT_REFRESH_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads/

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Map/Geolocation
MAP_API_KEY=your_map_api_key_here
